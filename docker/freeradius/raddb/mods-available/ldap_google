# Google Workspace Secure LDAP モジュール
# Phase 2で有効化
ldap ldap_google {
    server = "ldaps://ldap.google.com"
    port = 636

    # Google Workspace クライアント証明書認証
    tls {
        certificate_file = /etc/raddb/certs/google-ldap-client.crt
        private_key_file = /etc/raddb/certs/google-ldap-client.key
        require_cert = "demand"
        start_tls = no
    }

    # アクセス認証情報（Google Admin Consoleで発行）
    identity = "${GOOGLE_LDAP_USER}"
    password = "${GOOGLE_LDAP_PASS}"

    base_dn = "dc=kobedenshi,dc=ac,dc=jp"

    update {
        # Google Workspace LDAPではパスワードハッシュは取得不可
        # LDAP bindで認証する
    }

    user {
        base_dn = "${..base_dn}"
        filter = "(mail=%{%{Stripped-User-Name}:-%{User-Name}})"
    }

    options {
        chase_referrals = no
        rebind = yes
        res_timeout = 15
        srv_timelimit = 5
        net_timeout = 3
        idle = 60
        probes = 3
        interval = 3
    }

    pool {
        start = 1
        min = 1
        max = 5
        spare = 1
        uses = 0
        retry_delay = 30
        lifetime = 0
        idle_timeout = 60
    }
}
